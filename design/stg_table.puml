@startuml
entity "stg_stock_price" {
    * stock_id : BIGINT <<PK>>
--
    * ticker_symbol : VARCHAR(10)
    * trade_date : TIMESTAMP
    * open_price : NUMERIC(18,6)
    * high_price : NUMERIC(18,6)
    * low_price : NUMERIC(18,6)
    * close_price : NUMERIC(18,6)
    * volume : BIGINT
    * _source_name : VARCHAR(255)
    * _source_filename : VARCHAR(255)
    * _is_cleansed : BOOLEAN
    * _is_duplicate : BOOLEAN
    * _audit_hash : VARCHAR(64)
    * _transformation_version : INT
}

entity "stg_symbols" {
    * symbol : VARCHAR(10) <<PK>>
--
    * security_name : VARCHAR(255)
    * exchange : VARCHAR(100)
    * exchange_full_name : VARCHAR(100)
    * currency : VARCHAR(10)
    * sector : VARCHAR(100)
    * industry : VARCHAR(100)
    * ipo_date : DATE
    * is_active : BOOLEAN
    * _source_name : VARCHAR(255)
    * _source_filename : VARCHAR(255)
    * _audit_hash : VARCHAR(64)
}

@enduml