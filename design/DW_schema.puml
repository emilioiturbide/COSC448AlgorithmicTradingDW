@startuml
entity "dim_date" {
    * date_id : BIGINT <<PK>>
--
    * datetime : TIMESTAMP
    * date : DATE
    * hour : INT
    * minute : INT
    * second : INT
    * day_of_week : INT
    * day_name : VARCHAR(20)
    * day_of_month : INT
    * day_of_year : INT
    * month : INT
    * month_name : VARCHAR(20)
    * year : INT
    * quarter : INT
    * is_weekend : BOOLEAN
    * is_holiday : BOOLEAN
    * fiscal_year : INT
    * fiscal_quarter : INT
}

entity "dim_symbol" {
    * symbol_id : BIGINT <<PK>>
--
    * symbol : VARCHAR(10)
    * company_name : VARCHAR(255)
    * currency : VARCHAR(10)
    * sector : VARCHAR(100)
    * industry : VARCHAR(100)
    * country : VARCHAR(100)
    * state : VARCHAR(100)
    * city : VARCHAR(100)
    * ipo_date : DATE 
    * is_active : BOOLEAN
    * row_effective_ts : TIMESTAMP
    * row_end_ts : TIMESTAMP
}

entity "ExchangeDim" {
    * exchange_id : BIGINT <<PK>>
--
    * exchange_code : VARCHAR(10)
    * exchange_name : VARCHAR(100)
}

entity "FactDailyStockPrice" {
    * fact_id : BIGINT <<PK>>
--
    * stock_id : BIGINT <<FK>>
    * date_id : BIGINT <<FK>>
    * exchange_id : BIGINT <<FK>>
    * open_price : DECIMAL(18,6)
    * high_price : DECIMAL(18,6)
    * low_price : DECIMAL(18,6)
    * close_price : DECIMAL(18,6)
    * volume : BIGINT
    * adj_close : DECIMAL(18,6)
    * vwap : DECIMAL(18,6)
    * previous_close : DECIMAL(18,6)
    * price_change : DECIMAL(18,6)
    * price_change_pct : DECIMAL(5,2)
    * _audit_id : BIGINT <<FK>>
}

entity "meta_audit_log" {
    * audit_id : BIGINT <<PK>>
--
    * source_system : VARCHAR(100)
    * row_count_raw : BIGINT
    * row_count_rejected : BIGINT
    * execution_time : INT
    * status : VARCHAR(50)
}

FactDailyStockPrice }|..|| dim_date : "date_id"
FactDailyStockPrice }|..|| dim_symbol : "stock_id"
FactDailyStockPrice }|..|| ExchangeDim : "exchange_id"
FactDailyStockPrice }|..|| meta_audit_log : "_audit_id"
@enduml