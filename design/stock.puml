'Plant UML for an database ERD diagram of a stock table with stock_id, date, open, high, low, close, volume'
@startuml
entity "<Symbol>" {
    * stock_id : BIGINT <<PK>>
--
    * date : VARCHAR(50)
    * open : VARCHAR(50)
    * high : VARCHAR(50)
    * low : VARCHAR(50)
    * close : VARCHAR(50)
    * volume : VARCHAR(50)
    * _source_name : VARCHAR(255)
    * _source_filename : VARCHAR(255)
    * _loaded_at : TIMESTAMP
}

entity "symbol_info" {
    * symbol : VARCHAR(10) <<PK>>
--
    * company_name : VARCHAR(255)
    * exchange : VARCHAR(100)
    * exchange_full_name : VARCHAR(255)
    * industry : VARCHAR(100)
    * currency : VARCHAR(10)
    * website : VARCHAR(255)
    * description : TEXT
    * ceo : VARCHAR(100)
    * sector : VARCHAR(100)
    * country : VARCHAR(100)
    * full_time_employees : VARCHAR(50)
    * city : VARCHAR(100)
    * state : VARCHAR(100)
    * zip : VARCHAR(20)
    * address : VARCHAR(255)
    * ipo_date : VARCHAR(50)
    * is_active : VARCHAR(10)
    * is_etf : VARCHAR(10)
    * is_fund : VARCHAR(10)
    * _source_name : VARCHAR(255)
    * _source_filename : VARCHAR(255)
    * _loaded_at : TIMESTAMP
}

@enduml